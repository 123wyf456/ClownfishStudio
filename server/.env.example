APP_NAME=ClownfishStudio
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./clownfishstudio.db

# Brain provider
RADIO_AGENT_PROVIDER=mock
RADIO_AGENT_MODEL=gpt-5.4
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek provider
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Voice provider
TTS_PROVIDER=mock
FISH_AUDIO_API_KEY=
FISH_AUDIO_BASE_URL=https://api.fish.audio
FISH_AUDIO_VOICE_ID=

# Calendar provider
CALENDAR_PROVIDER=mock
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CALENDAR_ID=

# Weather provider
WEATHER_PROVIDER=mock
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org

# NetEase Cloud Music
# Windows-local NetEase API often resolves cleanly through localhost.
# If your backend runs inside WSL, `127.0.0.1` may also work depending on your setup.
# NETEASE_API_BASE_URL=http://localhost:3000
NETEASE_API_BASE_URL=
NETEASE_COOKIE=
NETEASE_PLAYBACK_LEVEL=standard
